# Honcho 环境变量配置
# 复制此文件为 .env 并填写 API Key
#
# 使用方法：
#   cd ~/.openclaw/honcho
#   cp .env.example .env
#   # 编辑 .env 填写你的 API Key
#   docker compose up -d --build

# =============================================================================
# LLM 提供商配置（必填至少一个）
# =============================================================================

# OpenAI 兼容接口（推荐：支持 OpenRouter、Together、Fireworks 等）
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_API_KEY=your-api-key-here

# 或者使用 Anthropic Claude
ANTHROPIC_API_KEY=

# 或者使用 Google Gemini
GEMINI_API_KEY=

# =============================================================================
# 应用设置（可选）
# =============================================================================

# 日志级别
LOG_LEVEL=INFO

# 最大消息大小（字符）
# MAX_MESSAGE_SIZE=25000

# 最大文件大小（字节）
# MAX_FILE_SIZE=5242880

# =============================================================================
# 认证设置（生产环境启用）
# =============================================================================

# 是否启用认证
AUTH_USE_AUTH=false

# JWT 密钥（如果启用认证，必须设置）
# AUTH_JWT_SECRET=your-secret-key-here
